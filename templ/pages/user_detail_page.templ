package pages

import (
	"strconv"
	"ego/models"
	"ego/templ/layouts"
)

templ UserDetailPage(user *models.User) {
	@layouts.DashboardLayout("User Detail", userDetailContent(user))
}

templ userDetailContent(user *models.User) {
	<div class="dashboard-content">
		<div class="card p-6 max-w-2xl">
			<h2 class="text-lg font-bold mb-4">Detail Pengguna</h2>
			<div class="space-y-3">
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">ID</span><span class="text-sm">{ user.ID }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Nama</span><span class="text-sm">{ user.Nama }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Email</span><span class="text-sm">{ user.Email }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Tipe MBTI</span><span class="text-sm font-bold">{ user.MBTITipe }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Status</span><span class="text-sm">{ user.StatusPembayaran }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Skor E/I</span><span class="text-sm">{ strconv.Itoa(user.SkorEI) }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Skor S/N</span><span class="text-sm">{ strconv.Itoa(user.SkorSN) }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Skor T/F</span><span class="text-sm">{ strconv.Itoa(user.SkorTF) }</span></div>
				<div class="flex"><span class="w-32 text-sm text-[var(--textMuted)]">Skor J/P</span><span class="text-sm">{ strconv.Itoa(user.SkorJP) }</span></div>
			</div>
			<div class="mt-6"><a href="/admin/dashboard" class="btn-ghost text-sm">&larr; Kembali ke Dashboard</a></div>
		</div>
	</div>
}