package layouts

import (
	tc "github.com/a-h/templ"
	"ego/templ/components"
)

templ DashboardLayout(title string, body tc.Component) {
	<!DOCTYPE html>
	<html lang="id">
		@components.Head(title)
		<body>
			<div class="dashboard-layout">
				@components.Sidebar()
				<div class="dashboard-main">
					@components.Topbar()
					<main>
						@body
					</main>
				</div>
			</div>
		</body>
	</html>
}